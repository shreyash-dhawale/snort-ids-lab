# $Id: local.rules,v 1.11 2004/07/23 20:15:44 bmc Exp $
# ----------------
# LOCAL RULES
# ----------------
# This file intentionally does not come with signatures.  Put your local
# additions here.

alert icmp any any -> $HOME_NET any (msg:"LOCAL ICMP Ping Detected"; sid:1000001; rev:1;)

alert tcp any any -> $HOME_NET 22 (msg:"LOCAL SSH Access Attempt"; flags:S; sid:1000002; rev:1;)

alert tcp any any -> $HOME_NET 80 (msg:"LOCAL SYN To HTTP Port"; flags:S; sid:1000003; rev:1;)

alert tcp any any -> $HOME_NET 80 (msg:"LOCAL Admin Page Probe"; content:"/admin", nocase; sid:1000004; rev:1;)
